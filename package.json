{
  "name": "site-md",
  "version": "0.2.5",
  "description": "Serve clean markdown from Next.js pages for AI agents",
  "license": "MIT",
  "homepage": "https://github.com/yazinsai/site-md#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yazinsai/site-md.git"
  },
  "bugs": {
    "url": "https://github.com/yazinsai/site-md/issues"
  },
  "keywords": [
    "nextjs",
    "markdown",
    "llms.txt",
    "ai-agents",
    "crawler",
    "llm",
    "seo",
    "content-negotiation"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "site-md": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js",
      "require": "./dist/proxy.cjs"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "import": "./dist/handler.js",
      "require": "./dist/handler.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "proxy": ["./dist/proxy.d.ts"],
      "handler": ["./dist/handler.d.ts"],
      "config": ["./dist/config.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude tests/integration.fixture.test.ts",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration.fixture.test.ts"
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.12",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^25.0.0",
    "lru-cache": "^11.0.0",
    "turndown": "^7.2.4"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@clack/prompts": "^1.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.6.0",
    "@types/turndown": "^5.0.6",
    "next": "^15.5.5",
    "picocolors": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recast": "^0.23.11",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
